# Backend (.env should live in backend/.env)

# Auth mode: 'clerk' (default, validates JWT) or 'dev' (local bypass)
AUTH_MODE=clerk

# Used only when AUTH_MODE=dev
DEV_USER_ID=local-dev-user

# Required for /api/chat
OPENAI_API_KEY=

# Required when AUTH_MODE=clerk
CLERK_JWKS_URL=

# Optional backend overrides
OPENAI_MODEL=gpt-4.1-mini
DATA_DIR=./data
CORS_ORIGINS=http://localhost:5173

# Frontend env vars (put these in frontend/.env or frontend/.env.local)
VITE_API_BASE_URL=http://localhost:8000
VITE_CLERK_PUBLISHABLE_KEY=
